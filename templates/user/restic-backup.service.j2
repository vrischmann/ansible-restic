[Unit]
Description=Restic backup ({{ item.name }})
After=network.target
OnFailure=restic-backup-notify@%n.service

[Service]
Type=oneshot
Environment=GOMAXPROCS={{ item.gomaxprocs|default(1) }}
{% if item.exec_start_pre is defined %}
{%   for cmd in (item.exec_start_pre | as_list) %}
ExecStartPre={{ cmd }}
{%   endfor %}
{% endif %}
ExecStart={{ restic_binary }} backup \
    --json \
    --exclude-caches \
    --exclude-file %h/.config/restic-backup/{{ item.name }}.excludes \
    --cache-dir %h/.cache/restic \
    --files-from %h/.config/restic-backup/{{ item.name }}.files
EnvironmentFile=%h/.config/restic-backup/{{ item.name }}.env
Nice=19
{% if item.exec_stop_post is defined %}
{%   for cmd in (item.exec_stop_post | as_list) %}
ExecStopPost={{ cmd }}
{%   endfor %}
{% endif %}

[Install]
WantedBy=basic.target
